{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "memory": 2048,
      "maxDuration": 120
    },
    "web": {
      "entrypoint": ".",
      "routePrefix": "/"
    }
  },
  "crons": [
    {
      "path": "/api/jobs/ingest/netkeiba/live-lite",
      "schedule": "*/5 0-13 * * *"
    },
    {
      "path": "/api/jobs/ingest/netkeiba/preday",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/jobs/ingest/netkeiba/results",
      "schedule": "30 7 * * *"
    }
  ]
}
