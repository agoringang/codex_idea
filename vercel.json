{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "api": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "memory": 2048,
      "maxDuration": 120
    },
    "web": {
      "entrypoint": ".",
      "routePrefix": "/"
    }
  },
  "crons": [
    {
      "path": "/api/jobs/ingest/netkeiba",
      "schedule": "15 21 * * *"
    }
  ]
}
